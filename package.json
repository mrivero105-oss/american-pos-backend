{
  "name": "americanpos",
  "version": "2.0.6",
  "author": {
    "name": "American POS Team",
    "email": "support@americanpos.com"
  },
  "description": "Sistema de Punto de Venta American POS",
  "main": "main.js",
  "scripts": {
    "start": "node index.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --watch",
    "electron:start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "node scratch/build_exe.js",
    "test:stress": "node test_stress_offline_sync.js",
    "test:math": "node test_vortex_engine.js",
    "test:zerotrust": "node test_zero_trust_sale.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.10",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "whatsapp-web.js": "^1.34.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "autoprefixer": "^10.4.23",
    "axios": "^1.18.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "googleapis": "^171.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  },
  "build": {
    "appId": "com.americanpos.frontend",
    "productName": "American POS",
    "compression": "normal",
    "npmRebuild": false,
    "asar": false,
    "directories": {
      "output": "dist_final_installer"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mrivero105-oss",
        "repo": "american-pos-backend"
      }
    ],
    "files": [
      "**/*",
      "!**/*.sqlite",
      "!**/serviceAccountKey.json",
      "!env_backup.txt",
      "!app_fixed.asar",
      "!test_backup.zip",
      "!.wwebjs_auth",
      "!.wwebjs_cache",
      "!dist_installer",
      "!dist_final_installer",
      "!dist_legacy_installer",
      "!backups",
      "!build_temp",
      "!auto-backups",
      "!scratch",
      "!uploads",
      "!*.log",
      "!db.json",
      "!.git",
      "!*.md",
      "!*.ps1",
      "!node_modules/electron",
      "!node_modules/electron-builder",
      "!node_modules/@electron/rebuild",
      "!node_modules/builder-util",
      "!node_modules/typescript"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "American POS",
      "include": "build/installer.nsh"
    }
  }
}
